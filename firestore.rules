rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: get user profile from Firestore
    function userProfile() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuth() && userProfile().perfil == role && userProfile().status == 'ativo';
    }

    function isAdminOrDH() {
      return isAuth() && userProfile().perfil in ['admin', 'dh'] && userProfile().status == 'ativo';
    }

    function isAnyActiveUser() {
      return isAuth() && userProfile().status == 'ativo';
    }

    // Usuarios: admin can manage all, others can read their own
    match /usuarios/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || hasRole('admin'));
      allow write: if hasRole('admin');
    }

    // Indicacoes: all active users can read, DH/admin can write
    match /indicacoes/{id} {
      allow read: if isAnyActiveUser();
      allow create, update: if isAdminOrDH();
      allow delete: if false; // No deletions
    }

    // Configuracoes: all read, DH/admin write
    match /configuracoes/{id} {
      allow read: if isAnyActiveUser();
      allow write: if isAdminOrDH();
    }

    // Historico: all can read, system writes
    match /historico/{id} {
      allow read: if isAnyActiveUser();
      allow create: if isAnyActiveUser();
      allow update, delete: if false;
    }
  }
}
